<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JewelryStoreCashFlowTracker.ViewModels"
             xmlns:models="using:JewelryStoreCashFlowTracker.Models"
             x:Class="JewelryStoreCashFlowTracker.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <Design.DataContext>
        <vm:DashboardViewModel />
    </Design.DataContext>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto,*" Margin="24" MaxWidth="1200" HorizontalAlignment="Stretch">
            <!-- Header with Current Balance -->
            <Border Grid.Row="0"
                    Classes="elevated"
                    Background="White"
                    CornerRadius="12"
                    Padding="32"
                    Margin="0,0,0,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#3F51B5" Offset="0" />
                        <GradientStop Color="#5C6BC0" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Current Balance"
                                   FontSize="14"
                                   Opacity="0.8"
                                   Foreground="White" />
                        <TextBlock Text="{Binding CurrentBalance, StringFormat='{}{0:C}'}"
                                   Classes="balance"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Button Content="Edit"
                                Command="{Binding EditInitialCashCommand}"
                                FontSize="11"
                                Padding="8,4"
                                CornerRadius="4"
                                Background="#FFFFFF"
                                Foreground="#3F51B5"
                                Opacity="0.9"
                                Margin="0,0,0,4" />
                        <TextBlock Text="Initial Cash"
                                   FontSize="12"
                                   Opacity="0.7"
                                   Foreground="White" />
                        <TextBlock Text="{Binding InitialCash, StringFormat='{}{0:C}'}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Metrics Cards -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,24">
                <!-- Money Enter Card -->
                <Border Grid.Column="0"
                        Classes="card"
                        Background="#E8F5E9"
                        BorderBrush="#4CAF50"
                        BorderThickness="0,0,0,4"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="MONEY ENTER"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#4CAF50"
                               Opacity="0.8" />
                        <TextBlock Text="{Binding TotalMoneyEnter, StringFormat='{}{0:C}'}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Money Leave Card -->
                <Border Grid.Column="1"
                        Classes="card"
                        Background="#FFEBEE"
                        BorderBrush="#F44336"
                        BorderThickness="0,0,0,4"
                        CornerRadius="8"
                        Padding="20"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="MONEY LEAVE"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="#F44336"
                               Opacity="0.8" />
                        <TextBlock Text="{Binding TotalMoneyLeave, StringFormat='{}{0:C}'}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#C62828"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Transactions Section -->
            <Grid Grid.Row="2" RowDefinitions="Auto,*">
                <!-- Section Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                    <TextBlock Grid.Column="0"
                               Text="Today's Transactions"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#212121"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Refresh"
                            Command="{Binding RefreshDashboardCommand}"
                            Padding="16,8"
                            CornerRadius="4" />
                </Grid>

                <!-- Transactions List -->
                <Border Grid.Row="1"
                        Classes="card"
                        Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="0"
                        MinHeight="250">
                    <Grid RowDefinitions="*,Auto">
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding TransactionRows}"
                                  SelectedItem="{Binding SelectedTransaction}"
                                  IsReadOnly="True"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  Height="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Description"
                                                    Binding="{Binding Description}"
                                                    Width="*"
                                                    MinWidth="150" />
                                <DataGridTextColumn Header="Amount Entered"
                                                    Binding="{Binding AmountEntered, StringFormat='{}{0:C}'}"
                                                    Width="120"
                                                    MinWidth="100" />
                                <DataGridTextColumn Header="Amount Left"
                                                    Binding="{Binding AmountLeft, StringFormat='{}{0:C}'}"
                                                    Width="120"
                                                    MinWidth="100" />
                                <DataGridTextColumn Header="Sold"
                                                    Binding="{Binding Sold, StringFormat='{}{0:C}'}"
                                                    Width="120"
                                                    MinWidth="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Edit Button -->
                        <Button Grid.Row="1"
                                Content="Edit Selected"
                                Command="{Binding EditTransactionCommand}"
                                IsEnabled="{Binding SelectedTransaction, Converter={x:Static ObjectConverters.IsNotNull}}"
                                HorizontalAlignment="Right"
                                Margin="16,8"
                                Padding="20,8"
                                Background="#2196F3"
                                Foreground="White" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
