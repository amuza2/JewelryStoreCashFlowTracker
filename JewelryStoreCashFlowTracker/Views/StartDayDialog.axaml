<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JewelryStoreCashFlowTracker.ViewModels"
             x:Class="JewelryStoreCashFlowTracker.Views.StartDayDialog"
             x:DataType="vm:StartDayDialogViewModel"
             MinWidth="400"
             MaxWidth="500"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">

    <Design.DataContext>
        <vm:StartDayDialogViewModel />
    </Design.DataContext>

    <Border Classes="dialog"
            Opacity="1"
            Background="White"
            CornerRadius="16"
            BoxShadow="0 8 32 0 #40000000"
            Padding="40">
        <Grid RowDefinitions="Auto,*,Auto" MaxWidth="420">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,32">
                <Border Background="#4CAF50"
                        CornerRadius="28"
                        Width="56"
                        Height="56"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock Text="$"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Start New Day"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#212121" />
                <TextBlock Text="Enter the initial cash amount in the register to begin the day"
                           FontSize="14"
                           Foreground="#757575"
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Content -->
            <StackPanel Grid.Row="1" Spacing="20">
                <StackPanel>
                    <TextBlock Text="INITIAL CASH"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#757575"
                               Margin="0,0,0,8" />
                    <Border Background="#F5F5F5"
                            CornerRadius="8"
                            Padding="16,4">
                        <TextBox Text="{Binding InitialCash, Mode=TwoWay}"
                                 Watermark="0.00"
                                 FontSize="24"
                                 FontWeight="SemiBold"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <!-- Error Message -->
                <Border Background="#FFEBEE"
                        CornerRadius="8"
                        Padding="12"
                        IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#C62828"
                               FontSize="13"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Margin="0,32,0,0">
                <Button Content="Start Day"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding CanSave}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#4CAF50"
                        Foreground="White"
                        Padding="20,16"
                        FontSize="16"
                        FontWeight="SemiBold"
                        CornerRadius="8">
                    <Button.Styles>
                        <Style Selector="Button:disabled">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Style>
                    </Button.Styles>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
